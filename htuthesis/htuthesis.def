%% ============================================================
%% htuthesis.def — HtuThesis 格式参数
%% ============================================================
%% 校准真值源：河南师范大学研究生学位论文格式要求 §2.3
%% 当前值：HTU 格式要求校准值
%% 校准日期：2026-06-13
%% ============================================================

%% ============================================================
%% 用户区 (User Zone)
%% 以下参数可根据需要修改。修改后重新编译即可生效。
%% ============================================================

% --- 学校身份 ---

% [基础] 学校名称（真值来源：HTU 官方信息）
\def\htu@schoolname{河南师范大学}

% [基础] 学校英文名称（真值来源：HTU 官方信息）
\def\htu@schoolname@en{Henan Normal University}

% [基础] 学校代码（真值来源：HTU 官方信息）
\def\htu@schoolcode@value{10476}

% --- 页面布局 ---

% [基础] 顶部边距 / includeheadfoot 下的 top 参数
% （真值来源：HTU 格式要求 §2.3 页眉 → 页眉距纸顶位置 = 2.2cm）
% 在 includeheadfoot 模式下，top = 页眉顶部距纸顶距离
\def\htu@topmargin{22mm}

% [基础] 底部边距 / includeheadfoot 下的 bottom 参数
% （真值来源：HTU 格式要求 §2.3 页脚 → 页脚距纸底位置 = 1.75cm）
% 在 includeheadfoot 模式下，bottom = 页脚基线距纸底距离
\def\htu@bottommargin{17.5mm}

% [基础] 左边距（真值来源：HTU 格式要求 §2.3 页面设置 → 左边距）
\def\htu@leftmargin{25mm}

% [基础] 右边距（真值来源：HTU 格式要求 §2.3 页面设置 → 右边距）
\def\htu@rightmargin{25mm}

% [基础] 页眉框高度（真值来源：参考论文实测横线在 27.5mm → top22mm + headheight ≈ 5.5mm；
%   fancyhdr 要求 headheight ≥ 五号字 + headruleskip(2pt) + 横线 ≈ 15.70pt = 5.53mm，取 5.6mm 留余量）
\def\htu@headerheight{5.6mm}

% [基础] 页眉与正文间距 headsep
% （推导值：上边距 3cm - 页眉位置 2.2cm - headheight 5.6mm = 2.4mm；参考论文实测横线→正文 ≈ 2.5mm）
% 约束：top + headheight + headsep = 30mm（正文起始位置 = HTU 上边距）
\def\htu@headsep{2.4mm}

% [基础] 页脚高度 / footskip（推导值：下边距 2.5cm - 页脚位置 1.75cm = 7.5mm）
% 约束：footskip + bottom = 25mm（正文结束位置 = HTU 下边距）
\def\htu@footskip{7.5mm}

% --- 正文字号与行距 ---

% [基础] 正文字号：小四号 = 12bp（标准中文排版字号，一般不需修改）
\def\htu@body@fontsize{12bp}

% [基础] 正文行距 = 1.5 倍小四号 = 18bp（真值来源：HTU 格式要求 §2.7/§2.9「小四号宋体，1.5 倍行间距」）
\def\htu@body@baselineskip{18bp}

% [基础] 显示公式前后间距（zzuthesis 原始模板 默认值）
\def\htu@display@skip{12bp}

% [基础] 显示公式间距伸缩量
\def\htu@display@stretch{2bp}

% --- 章节标题间距 ---

% [基础] 章标题段前间距 = 2 行（真值来源：HTU §2.10「一级标题段前 2 行」= 2×18bp）
\def\htu@chapter@beforeskip{36bp}

% [基础] 章标题段后间距 = 2 行（真值来源：HTU §2.10「一级标题段后 2 行」= 2×18bp）
\def\htu@chapter@afterskip{36bp}

% [基础] 章标题行距因子（zzuthesis 原始模板 研究生行距因子 1）
\def\htu@chapter@linespread{1}

% [基础] 节标题段前间距 = 0.5 行（真值来源：HTU §2.10「二级标题段前 0.5 行」= 0.5×18bp）
\def\htu@section@beforeskip{9bp}

% [基础] 节标题段后间距 = 0.5 行（真值来源：HTU §2.10「二级标题段后 0.5 行」= 0.5×18bp）
\def\htu@section@afterskip{9bp}

% [基础] 节标题行距因子（zzuthesis 原始模板 研究生行距因子 1.429）
\def\htu@section@linespread{1.429}

% [基础] 小节标题段前间距 = 0.5 行（真值来源：HTU §2.10「三级标题段前 0.5 行」= 0.5×18bp）
\def\htu@subsection@beforeskip{9bp}

% [基础] 小节标题段后间距 = 0.5 行（真值来源：HTU §2.10「三级标题段后 0.5 行」= 0.5×18bp）
\def\htu@subsection@afterskip{9bp}

% [基础] 小节标题行距因子（zzuthesis 原始模板 研究生行距因子 1.538）
\def\htu@subsection@linespread{1.538}

% [基础] 小小节标题段前间距 = 0.5 行（推断值：HTU §2.10 未明确四级，袭二三级 0.5 行 = 0.5×18bp）
\def\htu@subsubsection@beforeskip{9bp}

% [基础] 小小节标题段后间距 = 0.5 行（推断值：HTU §2.10 未明确四级，袭二三级 0.5 行 = 0.5×18bp）
\def\htu@subsubsection@afterskip{9bp}

% [基础] 小小节标题行距因子（zzuthesis 原始模板 研究生行距因子 1.667）
\def\htu@subsubsection@linespread{1.667}

%% ============================================================
%% 高级区 (Advanced Zone)
%% 以下参数为排版引擎内部使用，仅在有深入了解 LaTeX 时修改。
%% ============================================================

% --- 浮动对象 ---

% [基础] 浮动对象间距基准（zzuthesis 原始模板 默认值 12bp）
\def\htu@floatsep{12bp}

% [基础] 页面文本最小比例（zzuthesis 原始模板 默认值 0.15）
\def\htu@textfraction{0.15}

% [基础] 页顶浮动对象最大比例（zzuthesis 原始模板 默认值 0.85）
\def\htu@topfraction{0.85}

% [基础] 页底浮动对象最大比例（zzuthesis 原始模板 默认值 0.50）
\def\htu@bottomfraction{0.50}

% [基础] 浮动页最小占用比例（zzuthesis 原始模板 默认值 0.80）
\def\htu@floatpagefraction{0.80}

% --- 标题间距 ---

% [基础] 表格标题段前间距（zzuthesis 原始模板 研究生值 6bp）
\def\htu@caption@table@aboveskip{6bp}

% [基础] 表格标题段后间距（zzuthesis 原始模板 研究生值 6bp）
\def\htu@caption@table@belowskip{6bp}

% [基础] 图片标题段前间距（zzuthesis 原始模板 默认值 6bp）
\def\htu@caption@figure@aboveskip{6bp}

% [基础] 图片标题段后间距（zzuthesis 原始模板 默认值 12bp）
\def\htu@caption@figure@belowskip{12bp}

% [基础] 子图/子表间距（zzuthesis 原始模板 默认值 6bp）
\def\htu@caption@sub@skip{6bp}

% --- 图表公式编号 ---

% [基础] 图/表/公式编号分隔符 = 短横线（真值来源：HTU 格式要求 §2.11/§2.12/§2.13 + 硬约束「编号分隔符必须用短横线 -（非句号）」）
\def\htu@counter@separator{-}

% --- 页眉 ---

% [基础] 页眉线厚度（zzuthesis 原始模板 默认值 .4\p@）
\def\htu@header@rule@thickness{.4\p@}

% [基础] 页眉线与文字间距（zzuthesis 原始模板 默认值 \tw@\p@）
\def\htu@header@rule@gap{\tw@\p@}

% --- 脚注 ---

% [基础] 脚注行距因子（zzuthesis 原始模板 默认值 1.5）
\def\htu@footnote@linespread{1.5}

% --- 目录 ---

% [基础] 章节编号深度（zzuthesis 原始模板 默认值 3）
\def\htu@secnumdepth{3}

% [基础] 目录深度（zzuthesis 原始模板 默认值 2）
\def\htu@tocdepth{2}

% --- 摘要 ---

% [基础] 摘要关键词前间距（zzuthesis 原始模板 默认值 12bp）
\def\htu@abstract@keywordskip{12bp}
