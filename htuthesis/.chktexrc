# ChkTeX configuration for HTU thesis project
# Suppresses common false positives in Chinese academic LaTeX documents

TabSize = 2
CmdSpaceStyle = Ignore

# Mute warnings that are false positives in CJK/XeLaTeX documents:
#  1: Command terminated incorrectly (Chinese punctuation)
# 13: Intersentence spacing (not needed for CJK)
# 15: Double space (common in template)
# 22: \begin{table} should only contain tabular-like commands
# 44: Comment not terminated (CJK line endings)
CmdLine
{
    -n1 -n13 -n15 -n22 -n44
}
